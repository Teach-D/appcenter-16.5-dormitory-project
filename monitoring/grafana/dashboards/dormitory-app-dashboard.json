{
  "title": "Dormitory App - Application Performance & Business Metrics",
  "uid": "dormitory-app-main",
  "timezone": "Asia/Seoul",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (QPS)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"dormitory-app\"}[5m])",
          "legendFormat": "{{method}} {{uri}} - {{status}}",
          "refId": "A"
        },
        {
          "expr": "http_requests:5m:rate",
          "legendFormat": "5m Downsampled - {{method}} {{uri}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "format": "reqps", "label": "Requests/sec" },
        { "format": "short" }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (p95, p99)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"dormitory-app\"}[5m]))",
          "legendFormat": "p95 - {{method}} {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"dormitory-app\"}[5m]))",
          "legendFormat": "p99 - {{method}} {{uri}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "format": "s", "label": "Response Time" },
        { "format": "short" }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"dormitory-app\",status=~\"5..\"}[5m])",
          "legendFormat": "{{method}} {{uri}} - {{status}}",
          "refId": "A"
        },
        {
          "expr": "http_requests_error:5m:rate",
          "legendFormat": "5m Downsampled Error Rate",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "format": "reqps", "label": "Error Rate" },
        { "format": "short" }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Memory Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"dormitory-app\",area=\"heap\"}",
          "legendFormat": "Used - {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"dormitory-app\",area=\"heap\"}",
          "legendFormat": "Max - {{id}}",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_used_bytes:5m:avg",
          "legendFormat": "5m Avg Used",
          "refId": "C"
        }
      ],
      "yaxes": [
        { "format": "bytes", "label": "Memory" },
        { "format": "short" }
      ]
    },
    {
      "id": 5,
      "title": "JVM GC Pause Time",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"dormitory-app\"}[5m])",
          "legendFormat": "{{action}} - {{cause}}",
          "refId": "A"
        },
        {
          "expr": "jvm_gc_pause_seconds:5m:avg",
          "legendFormat": "5m Avg GC Time",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "format": "s", "label": "GC Time" },
        { "format": "short" }
      ]
    },
    {
      "id": 6,
      "title": "JVM Thread Count",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"dormitory-app\"}",
          "legendFormat": "Live Threads",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(jvm_threads_live_threads{application=\"dormitory-app\"}[5m])",
          "legendFormat": "5m Avg Threads",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "format": "short", "label": "Thread Count" },
        { "format": "short" }
      ]
    },
    {
      "id": 7,
      "title": "API Call Counts (5-minute intervals)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "lines": true,
      "linewidth": 2,
      "points": false,
      "pointradius": 5,
      "fill": 1,
      "fillGradient": 0,
      "steppedLine": false,
      "targets": [
        {
          "expr": "increase(announcement_find_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "announcement.find",
          "refId": "A"
        },
        {
          "expr": "increase(complaint_save_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "complaint.save",
          "refId": "B"
        },
        {
          "expr": "increase(roommate_chatting_send_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "roommate.chatting.send",
          "refId": "C"
        },
        {
          "expr": "increase(survey_find_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "survey.find",
          "refId": "D"
        },
        {
          "expr": "increase(tip_find_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "tip.find",
          "refId": "E"
        },
        {
          "expr": "increase(user_save_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "user.save",
          "refId": "F"
        },
        {
          "expr": "increase(roommate_save_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "roommate.save",
          "refId": "G"
        },
        {
          "expr": "increase(roommate_request_persistent{persistent=\"true\"}[5m]) or vector(0)",
          "legendFormat": "roommate.request",
          "refId": "H"
        }
      ]
    },
    {
      "id": 8,
      "title": "Cumulative API Calls (Persistent)",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "lines": true,
      "linewidth": 2,
      "points": false,
      "pointradius": 5,
      "fill": 1,
      "fillGradient": 0,
      "steppedLine": false,
      "targets": [
        {
          "expr": "announcement_find_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "announcement.find",
          "refId": "A"
        },
        {
          "expr": "complaint_save_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "complaint.save",
          "refId": "B"
        },
        {
          "expr": "roommate_chatting_send_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "roommate.chatting.send",
          "refId": "C"
        },
        {
          "expr": "survey_find_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "survey.find",
          "refId": "D"
        },
        {
          "expr": "tip_find_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "tip.find",
          "refId": "E"
        },
        {
          "expr": "user_save_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "user.save",
          "refId": "F"
        },
        {
          "expr": "roommate_save_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "roommate.save",
          "refId": "G"
        },
        {
          "expr": "roommate_request_persistent{persistent=\"true\"} or vector(0)",
          "legendFormat": "roommate.request",
          "refId": "H"
        }
      ],
      "yaxes": [
        { "format": "short", "label": "Total Calls (All Time)" },
        { "format": "short" }
      ],
      "description": "Cumulative API call counts stored in database"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["dormitory", "spring-boot", "performance", "business"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "version": 1
}